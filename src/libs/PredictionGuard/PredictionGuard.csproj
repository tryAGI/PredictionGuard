<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <NoWarn>$(NoWarn);CS3002;CS3003;CS1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Nuget">
    <Description>C# SDK for the Prediction Guard API -- LLM completions with built-in factuality, toxicity, and PII guardrails.</Description>
    <PackageId>PredictionGuard</PackageId>
    <PackageTags>api;client;sdk;dotnet;openapi;predictionguard;llm;guardrails;chat-completion;ai;autosdk</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.4.1" />
  </ItemGroup>

</Project>
